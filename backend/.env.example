PORT=5001
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/devutsav?retryWrites=true&w=majority

AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1

# Blog generator + Markdown→HTML (Bedrock InvokeModel / Claude). Falls back to BEDROCK_GENERAL_MODEL if unset.
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
# Optional: BLOG_HTML_DEBUG=1 logs when HTML uses Bedrock vs marked.
# BLOG_HTML_ENGINE=markdown (or marked, md) — Markdown-only HTML for posts; omit to use Bedrock LLM when configured.
# BLOG_HTML_MAX_TOKENS (default 3500, max 4095 for Claude Haiku output).

# Per-agent Bedrock model selection
BEDROCK_KUNDALI_MODEL=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_HOROSCOPE_MODEL=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_GENERAL_MODEL=anthropic.claude-3-haiku-20240307-v1:0

DEVPUNYA_PARTNER_ID=your_partner_id
